# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit it.

# ─────────────────────────────────────────────────────────────
# Phase 1 backend (FastAPI on Railway)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://tcos-insights-saas-production.up.railway.app

# ─────────────────────────────────────────────────────────────
# Supabase (same project as Phase 1 backend)
# Find these at: https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Server-side only (used in server components / route handlers).
# NEVER expose to the browser. Do NOT prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...
